generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Customer {
  id                   String    @id @default(cuid())
  name                 String
  email                String    @unique
  phone                String
  stripeCustomerId     String?
  status               String    @default("pending")
  browserbaseContextId String?   // persistent telco-login browser profile (trust-cookie store)
  activationStatus     String    @default("not_started") // not_started | in_progress | activated | failed
  notes                String?   // operator case notes
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  services             Service[]
  payment              Payment?
}

model Service {
  id                   String   @id @default(cuid())
  customerId           String
  customer             Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  serviceType          String   // "internet" | "cell_phone"
  provider             String   // "rogers" | "bell" | "telus" | "videotron" | "freedom" | "shaw"
  encryptedCredentials String   @default("") // AES-256-GCM encrypted JSON, populated post-payment
  status               String   @default("pending")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  event     String   // page_view | form_start | contact_submit | payment_success | payment_fail | credentials_submit
  sessionId String?
  meta      String?  // JSON
  createdAt DateTime @default(now())

  @@index([event])
  @@index([createdAt])
}

model SmsMessage {
  id         String   @id @default(cuid())
  customerId String?              // null if an inbound number matched no customer
  direction  String               // "outbound" | "inbound"
  fromNumber String?
  toNumber   String?
  body       String
  code       String?              // parsed 4–8 digit code from inbound body
  createdAt  DateTime @default(now())

  @@index([customerId])
  @@index([createdAt])
}

model Payment {
  id                    String    @id @default(cuid())
  customerId            String    @unique
  customer              Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  amount                Int       @default(3500)
  currency              String    @default("cad")
  paymentType           String    // "immediate" | "scheduled"
  scheduledDate         DateTime?
  stripePaymentIntentId String?
  stripePaymentMethodId String?
  status                String    @default("pending")
  paidAt                DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}
